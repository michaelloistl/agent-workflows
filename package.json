{
  "name": "agent-workflows",
  "version": "1.0.0",
  "private": true,
  "description": "Central reusable agent workflows — distributed to consuming repos as a git dependency exposing the agent-workflows hook dispatcher.",
  "bin": {
    "agent-workflows": "bin/agent-workflows.mjs"
  },
  "files": [
    "bin",
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.mts\" \"bin/**/*.test.mts\"",
    "sandcastle:explore": "node bin/agent-workflows.mjs explore run",
    "sandcastle:explore-guards": "node bin/agent-workflows.mjs explore guards",
    "sandcastle:explore-fetch-spec": "node bin/agent-workflows.mjs explore fetch-spec",
    "sandcastle:explore-status": "node bin/agent-workflows.mjs explore status",
    "sandcastle:explore-finalize": "node bin/agent-workflows.mjs explore finalize",
    "sandcastle:implement": "node bin/agent-workflows.mjs implement run",
    "sandcastle:implement-guards": "node bin/agent-workflows.mjs implement guards",
    "sandcastle:implement-fetch-spec": "node bin/agent-workflows.mjs implement fetch-spec",
    "sandcastle:implement-status": "node bin/agent-workflows.mjs implement status",
    "sandcastle:implement-finalize": "node bin/agent-workflows.mjs implement finalize",
    "sandcastle:review-pr": "node bin/agent-workflows.mjs review-pr run",
    "sandcastle:review-pr-guards": "node bin/agent-workflows.mjs review-pr guards",
    "sandcastle:review-pr-status": "node bin/agent-workflows.mjs review-pr status",
    "sandcastle:review-pr-finalize": "node bin/agent-workflows.mjs review-pr finalize",
    "sandcastle:implement-pr": "node bin/agent-workflows.mjs implement-pr run",
    "sandcastle:implement-pr-guards": "node bin/agent-workflows.mjs implement-pr guards",
    "sandcastle:implement-pr-status": "node bin/agent-workflows.mjs implement-pr status",
    "sandcastle:implement-pr-finalize": "node bin/agent-workflows.mjs implement-pr finalize",
    "sandcastle:update-branch": "node bin/agent-workflows.mjs update-branch run",
    "sandcastle:update-branch-guards": "node bin/agent-workflows.mjs update-branch guards",
    "sandcastle:update-branch-status": "node bin/agent-workflows.mjs update-branch status",
    "sandcastle:update-branch-finalize": "node bin/agent-workflows.mjs update-branch finalize",
    "sandcastle:implement-spec-guards": "node bin/agent-workflows.mjs implement-spec guards",
    "sandcastle:implement-spec-kickoff": "node bin/agent-workflows.mjs implement-spec kickoff",
    "sandcastle:implement-spec-advance": "node bin/agent-workflows.mjs implement-spec advance"
  },
  "dependencies": {
    "@ai-hero/sandcastle": "^0.7.0",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  }
}
